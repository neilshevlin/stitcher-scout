# Required: GitHub personal access token (needs public_repo or fine-grained with Contents:read, Metadata:read)
GITHUB_TOKEN=ghp_your_token_here

# LLM provider API key — set whichever you use:
ANTHROPIC_API_KEY=sk-ant-your_key_here
# OPENAI_API_KEY=sk-your_key_here
# GEMINI_API_KEY=your_key_here

# Optional: override the default model (default: claude-sonnet-4-20250514)
# STITCHER_MODEL=gpt-4o
# STITCHER_MODEL=gemini/gemini-2.0-flash
# STITCHER_MODEL=ollama/llama3

# Optional: search mode — "fast" (default) or "deep" (iterative refinement)
# STITCHER_MODE=deep

# Optional: max refinement iterations in deep mode (default: 3)
# STITCHER_MAX_REFINEMENT_LOOPS=3
